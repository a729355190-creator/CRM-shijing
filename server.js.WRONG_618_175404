// ========== v6 用户系统 ==========
function hashPwd(pwd) { return crypto.createHash('sha256').update(pwd + '::shijing-salt-v6').digest('hex'); }
function genToken() { return crypto.randomBytes(24).toString('hex'); }
function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2, 8); }

function getUserByToken(token) {
  if (!token) return null;
  const u = db.prepare(`SELECT * FROM shijing_users WHERE token=? AND status='approved'`).get(token);
  if (!u) return null;
  if (u.tokenExpire && u.tokenExpire < Date.now()) return null;
  return u;
}

// 鉴权中间件：必须是已审批通过的用户
function authRequired(req, res, next) {
  const token = req.headers['x-token'] || (req.body && req.body._token);
  const user = getUserByToken(token);
  if (!user) return res.status(401).json({ ok: false, error: 'not logged in or pending approval' });
  req.user = user;
  next();
}

// 总部专用
function hqRequired(req, res, next) {
  const token = req.headers['x-token'] || (req.body && req.body._token);
  const user = getUserByToken(token);
  if (!user) return res.status(401).json({ ok: false, error: 'not logged in' });
  if (user.role !== 'hq') return res.status(403).json({ ok: false, error: 'hq only' });
  req.user = user;
  next();
}

// === 注册 ===
app.post('/api/register', (req, res) => {
  const { username, password, realName, role, teamId } = req.body || {};
  if (!username || !password || !realName || !role || !teamId) return res.json({ ok: false, error: '请填写完整' });
  if (username.length < 3) return res.json({ ok: false, error: '用户名至少 3 字符' });
  if (password.length < 4) return res.json({ ok: false, error: '密码至少 4 字符' });

  const cfg = getConfig();
  if (!cfg.teams[teamId] || cfg.teams[teamId].role !== role) {
    return res.json({ ok: false, error: '业务线/部门不匹配' });
  }
  const exists = db.prepare(`SELECT id FROM shijing_users WHERE username=?`).get(username);
  if (exists) return res.json({ ok: false, error: '用户名已存在' });

  const id = uid();
  db.prepare(`INSERT INTO shijing_users(id, username, passwordHash, realName, role, teamId, status)
    VALUES(?, ?, ?, ?, ?, ?, 'pending')`)
    .run(id, username, hashPwd(password), realName, role, teamId);
  res.json({ ok: true, id, message: '注册成功，等待总部审批' });
});

// === 登录 ===
app.post('/api/login', (req, res) => {
  const { username, password } = req.body || {};
  if (!username || !password) return res.json({ ok: false, error: '请输入用户名和密码' });
  const u = db.prepare(`SELECT * FROM shijing_users WHERE username=?`).get(username);
  if (!u) return res.json({ ok: false, error: '用户名或密码错误' });
  if (u.passwordHash !== hashPwd(password)) return res.json({ ok: false, error: '用户名或密码错误' });
  if (u.status === 'pending') return res.json({ ok: false, error: '账号待审批，请联系总部' });
  if (u.status === 'rejected') return res.json({ ok: false, error: '账号被拒绝：' + (u.rejectReason || '未知原因') });
  if (u.status === 'disabled') return res.json({ ok: false, error: '账号已停用' });

  const token = genToken();
  const expire = Date.now() + 7 * 86400000; // 7 天
  db.prepare(`UPDATE shijing_users SET token=?, tokenExpire=? WHERE id=?`).run(token, expire, u.id);
  const cfg = getConfig();
  const teamName = (cfg.teams[u.teamId] && cfg.teams[u.teamId].name) || u.teamId;
  res.json({
    ok: true,
    token,
    user: { id: u.id, username: u.username, realName: u.realName, role: u.role, teamId: u.teamId, teamName },
  });
});

