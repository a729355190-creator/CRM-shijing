function fmtLocalDateFromTs(ts) {
  const d = new Date(ts || Date.now());
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}
function userVisibleFromDate(u) {
  return u && u.role !== 'hq' && /^\d{4}-\d{2}-\d{2}$/.test(String(u.dataVisibleFrom || ''))
    ? String(u.dataVisibleFrom)
    : '';
}
function recordBizDate(col, x) {
  if (!x) return '';
  if (col === 'invite') return String((x.arriveTime || '')).slice(0, 10) || fmtLocalDateFromTs(x.createdAt);
  return String((x.date || '')).slice(0, 10) || fmtLocalDateFromTs(x.createdAt);
}
function filterByVisibleFrom(col, list, u) {
  const from = userVisibleFromDate(u);
  if (!from) return list;
  return list.filter(x => recordBizDate(col, x) >= from);
}

// ===== API：业务数据 CRUD =====
app.post('/api/list', authRequired, (req, res) => {
  const u = req.user;
  const out = {};
  for (const c of COLLECTIONS) {
    const rows = db.prepare(`SELECT data FROM shijing_${c} WHERE deleted = 0`).all();
    out[c] = rows.map(r => JSON.parse(r.data));
  }
  // v6 权限过滤
  if (u.role === 'hq') {
    // 总部看全部
  } else if (u.role === 'ad') {
    // 营销线：只看自己提交的投放数据；其他表不可见；若配置了 dataVisibleFrom，则不能看加入前历史数据
    out.ad = filterByVisibleFrom('ad', out.ad.filter(x => x.createdByUserId === u.id), u);
    out.cs = []; out.store = []; out.invite = [];
  } else if (u.role === 'cs') {
    // 客服销售：只看自己提交的定金 + 自己提交的邀约；若配置了 dataVisibleFrom，则不能看加入前历史数据
    out.ad = [];
    out.cs = filterByVisibleFrom('cs', out.cs.filter(x => x.createdByUserId === u.id), u);
    out.invite = filterByVisibleFrom('invite', out.invite.filter(x => x.createdByUserId === u.id), u);
    out.store = []; // 客服不需要看门店服务记录
  } else if (u.role === 'store') {
    // 门店：能看本店的全部数据（不限定个人），但其他业务线不可见；若配置了 dataVisibleFrom，则不能看加入前历史数据
    out.ad = []; out.cs = [];
    out.store = filterByVisibleFrom('store', out.store.filter(x => x.teamId === u.teamId), u);
    out.invite = filterByVisibleFrom('invite', out.invite.filter(x => x.storeTeamId === u.teamId), u);
  }
  res.json({ ok: true, data: out, user: {
    id: u.id, username: u.username, realName: u.realName,
    role: u.role, teamId: u.teamId, dataVisibleFrom: u.dataVisibleFrom || '',
  } });
});

app.post('/api/add', authRequired, (req, res) => {
  const { collection: col, record } = req.body || {};
  if (!COLLECTIONS.includes(col) || !record || !record.id) return res.json({ ok: false, error: 'bad params' });
  // 注入身份信息（用于审计 + 权限过滤）
  record.createdByUserId = req.user.id;
  record.createdByUserName = req.user.realName;
  record.createdByUsername = req.user.username;
  if (!record.teamId) record.teamId = req.user.teamId;
  try {
    db.prepare(`INSERT INTO shijing_${col}(id, data) VALUES(?, ?)`).run(record.id, JSON.stringify(record));
    res.json({ ok: true });
  } catch (e) { res.json({ ok: false, error: e.message }); }
});

app.post('/api/update', authRequired, (req, res) => {
  const { collection: col, id, data } = req.body || {};
  if (!COLLECTIONS.includes(col) || !id || !data) return res.json({ ok: false, error: 'bad params' });
  try {
    const row = db.prepare(`SELECT data FROM shijing_${col} WHERE id=?`).get(id);
    if (!row) return res.json({ ok: false, error: 'not found' });
    const orig = JSON.parse(row.data);
    // 权限：非总部不能改别人的数据（门店例外：可以反馈本店邀约）
    const u = req.user;
    if (u.role !== 'hq') {
      const isOwn = orig.createdByUserId === u.id;
      const isStoreOwnInvite = u.role === 'store' && col === 'invite' && orig.storeTeamId === u.teamId;
      if (!isOwn && !isStoreOwnInvite) return res.json({ ok: false, error: '无权修改' });
    }
    const merged = Object.assign(orig, data);
    db.prepare(`UPDATE shijing_${col} SET data=? WHERE id=?`).run(JSON.stringify(merged), id);
    res.json({ ok: true });
  } catch (e) { res.json({ ok: false, error: e.message }); }
});

app.post('/api/delete', authRequired, (req, res) => {
  const { collection: col, id } = req.body || {};
  if (!COLLECTIONS.includes(col) || !id) return res.json({ ok: false, error: 'bad params' });
  try {
    const row = db.prepare(`SELECT data FROM shijing_${col} WHERE id=?`).get(id);
    if (!row) return res.json({ ok: false, error: 'not found' });
    const orig = JSON.parse(row.data);
    const u = req.user;
    if (u.role !== 'hq') {
      // 非总部只能删自己的（门店可删本店的）
      const isOwn = orig.createdByUserId === u.id;
      const isStoreOwn = u.role === 'store' && orig.teamId === u.teamId;
      if (!isOwn && !isStoreOwn) return res.json({ ok: false, error: '无权删除' });
    }
    db.prepare(`UPDATE shijing_${col} SET deleted=1, deletedAt=? WHERE id=?`).run(Date.now(), id);
    res.json({ ok: true });
  } catch (e) { res.json({ ok: false, error: e.message }); }
});

