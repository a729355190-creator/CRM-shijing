function setConfig(cfg) {
  const j = JSON.stringify(cfg);
  db.prepare(`INSERT INTO shijing_config(id, data, updatedAt) VALUES('main', ?, ?)
    ON CONFLICT(id) DO UPDATE SET data=excluded.data, updatedAt=excluded.updatedAt`)
    .run(j, Date.now());
}

